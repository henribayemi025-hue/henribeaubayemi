# Cloudflare cache policy for the Finjaro SPA.
# Content-hashed assets are immutable and cached hard; the shell + service
# worker must always revalidate so a new deploy takes effect immediately
# (no reinstall). Mirrors the old netlify.toml headers, now on Cloudflare.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache, must-revalidate
